# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-me-with-a-long-random-string
ADMIN_PANEL_PASSWORD=change-this-admin-password

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://stablecasino:stablecasino@localhost:5432/stablecasino?schema=public

# --- Solana ---
# Helius mainnet (recommended). Get a free API key at https://helius.dev
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_CLUSTER=mainnet-beta

# Token mints (placeholders until launch; replace post-launch)
STABLE_MINT=So11111111111111111111111111111111111111112
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Decimals
STABLE_MINT_DECIMALS=6
USDC_MINT_DECIMALS=6

# Casino bankroll (server-custodied) - DO NOT commit real keys
CASINO_BANKROLL_PUBLIC_KEY=11111111111111111111111111111111
CASINO_BANKROLL_PRIVATE_KEY=replace-with-base58-secret-key

# Burn address (loss-side stablecoin sink). The SPL "incinerator" account is a common choice.
BURN_ADDRESS=1nc1nerator11111111111111111111111111111111

# Pump.fun creator/owner public key whose fees we accumulate
PUMP_CREATOR_PUBLIC_KEY=11111111111111111111111111111111

# --- House / Risk ---
HOLDER_MIN_BALANCE=1
HOUSE_EDGE_BPS=0
# Max bet = available bankroll * fraction / worst-case payout multiplier
MAX_BET_BANKROLL_FRACTION_BPS=200
# Min bet derives from max bet (max/MIN_BET_RATIO_DIVISOR) but never below the floor.
MIN_BET_RATIO_DIVISOR=100
MIN_BET_FLOOR_USDC=0.1
ABSOLUTE_MAX_BET_USDC=500

# --- Pump.fun coin info ---
# Public Pump.fun frontend API endpoint (no key required). Used for live price/market cap.
PUMP_FRONTEND_API_URL=https://frontend-api-v3.pump.fun
COIN_INFO_CACHE_MS=15000

# --- Schedulers ---
# Auto-collect Pump.fun creator fees every FEE_COLLECT_INTERVAL_MS.
# Requires CASINO_BANKROLL_PRIVATE_KEY == signer authorized for PUMP_CREATOR_PUBLIC_KEY.
AUTO_COLLECT_FEES=true
FEE_COLLECT_INTERVAL_MS=10000
# Auto-airdrop the 50% holder allocation every AIRDROP_INTERVAL_MS to the top N holders.
AUTO_AIRDROP=true
AIRDROP_INTERVAL_MS=1800000
AIRDROP_TOP_N=20
# Skip airdrop rounds if the pending pool is below this many USDC base units
# (6 decimals; 1000000 = 1 USDC).
AIRDROP_MIN_USDC_BASE=0
# Comma-separated wallet pubkeys to skip when picking top holders
# (bankroll, burn, pump bonding curve, creator etc. are auto-excluded too).
AIRDROP_EXCLUDE_OWNERS=
# Top-holders endpoint cache (used by homepage list).
TOP_HOLDERS_CACHE_MS=30000
